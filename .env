# ==============================================================================
# MMS PROJECT ENVIRONMENT CONFIGURATION
# ==============================================================================

# Timezone
TZ=Asia/Bangkok

# MQTT Broker Settings
MQTT_BROKER=mosquitto
MQTT_PORT=1883

# Redis Buffer Settings
REDIS_HOST='192.168.1.30'
REDIS_PORT=6379


# Apache Kafka Settings
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ClickHouse OLAP Settings
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=maibok
CLICKHOUSE_DATABASE=default

# PostgreSQL App DB Settings
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=iiot_db

# Device Checker Settings
PERIOD=300

# API & Dashboard Services Ports
DASHBOARD_PORT=8001
SSE_PORT=8002
REST_PORT=8003

