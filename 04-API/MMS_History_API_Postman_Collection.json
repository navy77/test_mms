                                ":process"
                            ],
                            "query": [
                                {
                                    "key": "devices",
                                    "value": "no_1,no_2",
                                    "description": "Optional comma-separated device names, e.g. no_1,no_2,no_3. When omitted, returns all registered devices for the process."
                                }
                            ],
                            "variable": [
                                {
                                    "key": "process",
                                    "value": "demo1",
                                    "description": "Path variable for process"
                                }
                            ]
                        },
                        "description": "Fetch state timelines for requested or all registered devices in one batch query.\n\nWhen ``devices`` is omitted, every device registered for ``process`` is queried.\nData is queried from ClickHouse on every request; no in-memory cache is used.\n\nResponse: { \"no_1\": [...segments], \"no_2\": [...segments], ... }"
