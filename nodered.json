    {
        "id": "func_data_loop",
        "type": "function",
        "z": "flow_tab_mqtt_simulation",
        "name": "Generate Data",
        "func": "let qty_topic = 10;\nlet baseTopic = \"data/mic/demo1/\";\nlet msg_loop = flow.get(\"msg_loop\") || 1;\n\nfor (let j = 1; j <= qty_topic; j++) {\n    let payload = {\n        data1: msg_loop,\n        data2: msg_loop,\n        data3: msg_loop,\n        data4: msg_loop,\n        data5: msg_loop,\n        model: \"A\"\n    };\n    node.send({\n        topic: baseTopic + \"no_\" + j,\n        payload: payload\n    });\n}\n\nflow.set(\"msg_loop\", msg_loop + 1);\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 100,
        "wires": [
            [
                "mqtt_out_node"
            ]
        ]
    },
