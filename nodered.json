        ]
    },
    {
        "id": "func_alarm_loop",
        "type": "function",
        "z": "flow_tab_mqtt_simulation",
        "name": "Generate Alarm",
        "func": "let qty_topic = 10;\nlet baseTopic = \"alarm/mic/demo1/\";\n\nfor (let j = 1; j <= qty_topic; j++) {\n    let alarmIndex = Math.floor(Math.random() * 4) + 1;\n    let alarmName = \"alarm\" + alarmIndex;\n    let topic = baseTopic + \"no_\" + j;\n\n    // Send Active Alarm\n    node.send({\n        topic: topic,\n        payload: { status: alarmName }\n    });\n\n    // Close Alarm after 1 second\n    setTimeout(() => {\n        node.send({\n            topic: topic,\n            payload: { status: alarmName + \"_\" }\n        });\n    }, 1000);\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 260,
        "wires": [
            [
                "mqtt_out_node"
            ]
        ]
    },
