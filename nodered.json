    {
        "id": "func_esp32_loop",
        "type": "function",
        "z": "flow_tab_mqtt_simulation",
        "name": "Generate ESP32",
        "func": "let qty_topic = 10;\nlet baseTopic = \"mqtt/mic/demo1/\";\n\nfor (let j = 1; j <= qty_topic; j++) {\n    let macId = \"mac-\" + Math.floor(Math.random() * 10);\n    node.send({\n        topic: baseTopic + \"no_\" + j,\n        payload: {\n            broker: 1,\n            modbus: 1,\n            mac_id: macId\n        }\n    });\n}\nreturn null;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 340,
        "y": 340,
        "wires": [
